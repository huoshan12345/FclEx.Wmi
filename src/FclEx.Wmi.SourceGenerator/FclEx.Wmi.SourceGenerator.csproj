<Project Sdk="Microsoft.NET.Sdk">
  
  <PropertyGroup>
    <!--To fix the error 'The library 'hostpolicy.dll' required to execute the application was not found'-->
    <OutputType>exe</OutputType>
    <TargetFrameworks>net9.0-windows</TargetFrameworks>
    <IsPackable>false</IsPackable>
    <EnforceExtendedAnalyzerRules>true</EnforceExtendedAnalyzerRules>
    <NoWarn>RS1035;CS1591</NoWarn>
  </PropertyGroup>
  
  <ItemGroup>
    <Compile Remove="FclEx\Wmi\SourceGenerator\Extensions\**" />
    <EmbeddedResource Remove="FclEx\Wmi\SourceGenerator\Extensions\**" />
    <None Remove="FclEx\Wmi\SourceGenerator\Extensions\**" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="FclEx.Core" Version="1.7.4" />
    <PackageReference Include="System.Management" Version="9.0.3" />
    <PackageReference Include="Microsoft.CodeAnalysis.CSharp" Version="4.13.0" PrivateAssets="all" />
    <PackageReference Include="Microsoft.CodeAnalysis.Analyzers" Version="3.11.0" PrivateAssets="all" />
  </ItemGroup>

</Project>
